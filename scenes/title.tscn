[gd_scene format=3]

[ext_resource type="Script" path="res://scripts/title.gd" id="1_title"]

[node name="Title" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_title")

[node name="BG" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0.12, 0.15, 0.1, 1)

[node name="VBox" type="VBoxContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
alignment = 1
theme_override_constants/separation = 40

[node name="GameTitle" type="Label" parent="VBox"]
layout_mode = 2
text = "Defense Game"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 64

[node name="SubTitle" type="Label" parent="VBox"]
layout_mode = 2
text = "타워를 배치하여 적을 막아라!"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 24

[node name="Spacer" type="Control" parent="VBox"]
layout_mode = 2
custom_minimum_size = Vector2(0, 40)

[node name="StartButton" type="Button" parent="VBox"]
layout_mode = 2
custom_minimum_size = Vector2(300, 80)
size_flags_horizontal = 4
text = "게임 시작"
theme_override_font_sizes/font_size = 36
